{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_SUBAGENT_MODEL": "claude-opus-4-6"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-nagger hook session-startup"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "claude-nagger hook implementation-design"
          }
        ]
      },
      {
        "matcher": "SendMessage",
        "hooks": [
          {
            "type": "command",
            "command": "claude-nagger hook sendmessage-guard"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-nagger notify \"📢 Claude Code から通知があります\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-nagger notify \"🛑 Claude Code セッションが停止されました\""
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-nagger hook suggest-rules-trigger"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-nagger hook transcript-storage"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-nagger hook subagent-event"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-nagger hook subagent-event"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "claude-nagger hook compact-detected"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__redmine_epic_grid__.*",
        "hooks": [
          {
            "type": "command",
            "command": "claude-nagger hook redmine-discord"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/statusline.js"
  },
  "extraKnownMarketplaces": {
    "ticket-tasuki": {
      "source": {
        "source": "directory",
        "path": ".claude/plugins/ticket-tasuki"
      },
      "autoUpdate": true
    }
  },
  "enabledPlugins": {
    "ticket-tasuki@ticket-tasuki": true
  }
}
